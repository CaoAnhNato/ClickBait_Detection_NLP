# --- Backend Settings ---
CLICKBAIT_BACKEND_HOST=0.0.0.0
CLICKBAIT_BACKEND_PORT=8000
CORS_ALLOW_ORIGINS=*

# --- Model & API Key Configuration ---
# API Key for OpenAI, Gemini or other LLMs used in zero/few-shot detection
ORCD_API_KEY=sk-xxxx-replace-with-your-key

# Define which model to use as the primary model. 
# Examples: gemini-zero, gpt-4o, roberta-large, etc.
ORCD_MODEL_KEY=gemini-zero

# Define your custom API proxy or base URL if not using the default one
ORCD_API_BASE_OVERRIDE=https://api.openai.com/v1

# --- Optional Paths ---
# ORCD_WEIGHT_PATH=ORCD/GPT_3.5/weight/best_teachermodel.pth
# BERT_MODEL_PATH=./my_bert_model
